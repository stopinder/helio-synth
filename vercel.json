{
  "version": 2,
  "buildCommand": "bash build.sh",
  "installCommand": "echo 'Skipping install, handled in build.sh'",
  "framework": "nextjs",
  "regions": ["iad1"],
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "NODE_ENV": "production",
    "NODE_VERSION": "18.17.0"
  },
  "build": {
    "env": {
      "NODE_VERSION": "18.17.0",
      "NODE_ENV": "production"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "fix-build": true
    }
  }
} 