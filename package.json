{
  "name": "helio-synth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001 -H 127.0.0.1",
    "build": "build": "next build"
    "start": "next start",
    "deploy": "bash deploy.sh",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true next build",
    "clean": "rm -rf .next && rm -rf node_modules/.cache",
    "lighthouse": "lighthouse http://localhost:3001 --view",
    "find-deadcode": "next-unused",
    "audit": "npm audit && npm run lighthouse",
    "test:accessibility": "jest --config jest.accessibility.config.js",
    "lint:accessibility": "eslint --ext .ts,.tsx --plugin jsx-a11y --rule 'jsx-a11y/rule-name: 2' src/",
    "audit:accessibility": "pa11y-ci",
    "build:accessibility": "next build && npm run audit:accessibility"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@supabase/supabase-js": "^2.39.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "framer-motion": "^12.7.3",
    "lucide-react": "^0.358.0",
    "next": "14.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.29.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^3.5.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.1.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "axe-core": "^4.10.3",
    "eslint": "^8",
    "eslint-config-next": "^14.1.0",
    "eslint-plugin-jsx-a11y": "^6.7.0",
    "jest": "^29.7.0",
    "jest-axe": "^7.0.1",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^11.7.0",
    "next-unused": "^0.0.6",
    "pa11y-ci": "^3.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "next-unused": {
    "alias": {
      "@/*": [
        "./app/*"
      ]
    },
    "include": [
      "app"
    ],
    "exclude": [],
    "entrypoints": [
      "app/page.tsx"
    ]
  }
}
